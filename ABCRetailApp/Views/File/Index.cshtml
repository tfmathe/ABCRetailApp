@using System.IO
@using Azure.Storage.Files.Shares.Models
@model List<ShareFileItem>
@{
    ViewData["Title"] = "Log Files";
}
<h2>📁 Log Files (Azure File Storage)</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5>Upload Log File</h5>
        <form method="post" asp-action="Upload" asp-controller="File"
              enctype="multipart/form-data">
            <div class="input-group">
                <input type="file" name="file" class="form-control" required />
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr><th>#</th><th>File Name</th><th>Size</th><th>Action</th></tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>@(i + 1)</td>
                <td>@Model[i].Name</td>
                <td>
                    @(Model[i].FileSize.HasValue
                                    ? $"{Model[i].FileSize / 1024.0:F1} KB" : "N/A")
            </td>
            <td>
                <a asp-action="Delete" asp-controller="File"
                   asp-route-fileName="@Model[i].Name"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Delete this log?')">
                    Delete
                </a>
            </td>
        </tr>
                }
    </tbody>
</table>
<p><strong>Total Log Files: @Model.Count</strong></p>