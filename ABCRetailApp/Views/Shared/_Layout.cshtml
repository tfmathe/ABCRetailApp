<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ABC Retail</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🛒 ABC Retail
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" asp-controller="Blob" asp-action="Index">Images</a>
                <a class="nav-link" asp-controller="Table" asp-action="Customers">Customers</a>
                <a class="nav-link" asp-controller="Table" asp-action="Products">Products</a>
                <a class="nav-link" asp-controller="Queue" asp-action="Index">Orders</a>
                <a class="nav-link" asp-controller="File" asp-action="Index">Logs</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>